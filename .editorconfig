root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{json,yml,yaml,toml}]
indent_size = 2

[LICENSE]
insert_final_newline = false
