# Local mirror of the CI test workflows. Keep the CLI version in sync with
# .github/actions/run-feature-test/action.yml.

cli_version := "0.87.0"
default_image := "mcr.microsoft.com/devcontainers/base:ubuntu"

# Install the pinned Dev Container CLI.
setup:
    npm install -g "@devcontainers/cli@{{cli_version}}"

# Default-options test for one feature.
test feature image=default_image:
    devcontainer features test --project-folder . \
      --skip-scenarios --skip-duplicated \
      -f {{feature}} -i {{image}}

# Repeat-install (idempotency) test for one feature.
test-duplicate feature image=default_image:
    devcontainer features test --project-folder . \
      --skip-scenarios --skip-autogenerated \
      -f {{feature}} -i {{image}}

# Scenario tests for one feature (scenarios pin their own images).
test-scenarios feature:
    devcontainer features test --project-folder . \
      --skip-autogenerated --skip-duplicated -f {{feature}}

# Repo-global cross-feature scenarios.
test-global:
    devcontainer features test --project-folder . --global-scenarios-only

# Default-options test across every image in test/<id>/compatibility.txt.
test-compat feature:
    #!/usr/bin/env bash
    set -euo pipefail
    while IFS= read -r image || [ -n "$image" ]; do
      image="${image%$'\r'}"
      [[ -z "$image" || "$image" =~ ^[[:space:]]*# ]] && continue
      just test {{feature}} "$image"
    done < "test/{{feature}}/compatibility.txt"

# Syntax-check every feature manifest.
validate:
    #!/usr/bin/env bash
    set -euo pipefail
    for f in src/*/devcontainer-feature.json; do
      jq empty "$f" && echo "ok: $f"
    done

# Shell lint over install and test scripts.
lint:
    shellcheck -S error src/*/*.sh test/*/*.sh
